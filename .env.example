# ============================================================
# AnyRouter 自动签到 - 环境变量示例
# 复制为 .env 并填入实际值。.env 已被 .gitignore 忽略。
# ============================================================

# ----- 必填:账号配置(JSON 数组) -----
# 单条账号支持以下字段:
#   name             账号名称(用于日志和 profile 目录)
#   provider         平台: "anyrouter" | "agentrouter"
#   domain           可选,自定义域名(覆盖 provider 默认值)
#   cookies          可选, {"session": "xxx"} - 直接复用平台 session
#   github_session   可选,GitHub 完整 cookies JSON 列表(agentrouter 首次引导用)
#   username/password 可选,平台账号密码(anyrouter 推荐)
#   api_user         可选,部分平台需要的 New-Api-User header
#
# AgentRouter 推荐: 首次填 github_session 引导,之后 profile 自动维护
# 失效时运行: python checkin.py --relogin <name> 重新登录
ANYROUTER_ACCOUNTS=[{"name":"AgentRouter主账号","provider":"agentrouter","github_session":[{"name":"user_session","value":"YOUR_USER_SESSION","domain":"github.com"},{"name":"__Host-user_session_same_site","value":"YOUR_USER_SESSION","domain":"github.com"},{"name":"_gh_sess","value":"YOUR_GH_SESS","domain":"github.com"},{"name":"logged_in","value":"yes","domain":".github.com"},{"name":"dotcom_user","value":"YOUR_GITHUB_USERNAME","domain":".github.com"}]},{"name":"AnyRouter账号1","provider":"anyrouter","username":"YOUR_USERNAME","password":"YOUR_PASSWORD"}]

# ----- 可选:Server 酱推送 -----
# 拿到余额/签到结果后推送到微信。从 https://sct.ftqq.com/ 申请
SERVERCHAN_KEY=

# ----- 可选:GitHub Session 全局值 -----
# 当 ANYROUTER_ACCOUNTS 中未指定 github_session 时使用
GITHUB_SESSION=
