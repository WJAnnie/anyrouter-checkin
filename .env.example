# ============================================================
# AnyRouter 自动签到 - 环境变量示例
# 复制为 .env 并填入实际值。.env 已被 .gitignore 忽略。
# ============================================================

# ----- 必填:账号配置(JSON 数组) -----
# 单条账号支持以下字段:
#   name             账号名称(用于日志和 profile 目录)
#   provider         平台: "anyrouter" | "agentrouter"
#   domain           可选,自定义域名(覆盖 provider 默认值)
#   login_path       可选,登录接口路径(默认 /api/user/login)
#   sign_in_path     可选,签到接口路径(默认 /api/user/sign_in)
#   supports_sign_in 可选,是否调用签到接口(默认 true)
#   cookies          可选, {"session": "xxx"} - 直接复用平台 session
#   github_session   可选,GitHub 完整 cookies JSON 列表(agentrouter OAuth 备用)
#   username/password 可选,平台账号密码(anyrouter / agentrouter 推荐)
#   api_user         可选,部分平台需要的 New-Api-User header
#
# AgentRouter 现在支持账号密码登录,推荐直接填 username/password。
# 多账号时在数组里继续追加对象即可。
ANYROUTER_ACCOUNTS=[{"name":"AgentRouter账号1","provider":"agentrouter","username":"YOUR_AGENTROUTER_USERNAME","password":"YOUR_AGENTROUTER_PASSWORD"},{"name":"AnyRouter账号1","provider":"anyrouter","username":"YOUR_ANYROUTER_USERNAME","password":"YOUR_ANYROUTER_PASSWORD"}]

# ----- 可选:Server 酱推送 -----
# 拿到余额/签到结果后推送到微信。从 https://sct.ftqq.com/ 申请
SERVERCHAN_KEY=

# ----- 可选:GitHub Session 全局值 -----
# 当 ANYROUTER_ACCOUNTS 中未指定 github_session 时使用
GITHUB_SESSION=
